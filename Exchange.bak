from datetime import datetime


class UserInterface:
    def __init__(self, order_book, price_feed, companies):
        self.order_book = order_book
        self.price_feed = price_feed
        self.companies = companies
        self.current_mode = 'terminal'


    def run(self):
        self.choose_interface()
        while True:
            if self.current_mode == 'menu':
                self.menu_mode()
            elif self.current_mode == 'terminal':
                self.terminal_mode()

    def _process_menu_choice(self, choice):
        try:
            if choice == 1:
                self.place_market_order('BUY')
            elif choice == 2:
                self.place_market_order('SELL')
            elif choice == 3:
                self.place_limit_order('BUY')
            elif choice == 4:
                self.place_limit_order('SELL')
            elif choice == 5:
                self.show_market_data()
            elif choice == 6:
                self.display_orders()
            elif choice == 7:
                self.current_mode = 'terminal'
                print('Переключено в режим терминала')
            elif choice == 8:
                print('Выход из программы')
                exit()
            else:
                print('Неверный номер пункта меню. Выберите от 1 до 8.')
        except ValueError as ve:
            print(f'Ошибка ввода: {ve}')
        except Exception as e:
            print(f'Неожиданная ошибка: {e}')

    def terminal_mode(self):
        try:
            command = input('Action: ').strip().upper()
            self.process_terminal_command(command)
        except Exception as e:
            print(f'Ошибка: {e}')

    def menu_mode(self):
        print('Выберите действие и введите его номер:')
        print('1. Разместить рыночный ордер на покупку\n'
              '2. Разместить рыночный ордер на продажу\n'
              '3. Разместить лимитный ордер на покупку\n'
              '4. Разместить лимитный ордер на продажу\n'
              '5. Получить последнюю цену ордера\n'
              '6. Просмотреть ордера\n'
              '7. Переключиться в режим терминала\n'
              '8. Выход')

        try:
            choice = int(input('Action: '))
            self.process_menu_choice(choice)
        except ValueError:
            print('Введите число от 1 до 8')


    def choose_interface(self):

        print('Выберите способ ввода:')
        print('1. Терминал (по умолчанию)\n'
              '2. Меню выбора\n'
              'Чтобы пропустить нажмите Enter')

        number = input('Action: ')
        if number == '2':
            self.current_mode = 'menu'


    def process_terminal_command(self, command):
        if command == 'VIEW ORDERS':
            self.display_orders()
        elif command == 'SWITCH INTERFACE':
            self.current_mode = 'menu'
            print('Переключено в режим меню')
        elif command == 'QUIT':
            exit()
        else:
            parts = command.split()
        if len(parts) >= 3:
            action, company, order_type = parts[0], parts[1], parts[2]
            order = self.create_order_from_parts(parts)
            if order:
                self.order_book.add_order(order)


    def create_order_from_parts(self, parts):
        action, company, order_type = parts[0], parts[1], parts[2]
        if company not in self.companies:
            raise ValueError('Компании нет на бирже')
        if order_type == 'LMT':
            price = float(parts[3].replace('$', ''))
            quantity =  int(parts[4])
            if quantity <= 0:
                raise ValueError('Количество должно быть положительным')
            if price <= 0:
                raise ValueError('Цена должна быть положительной')
            return self.order_book.create_limit_order(action, company, price, quantity)
        elif order_type == 'MKT':
            quantity = int(parts[3])
            if quantity <= 0:
                raise
            return self.order_book.create_market_order(action, company, quantity)

    def display_orders(self):
        if not self.order_book.all_orders:
            print('Ордеров нет')

        for order in self.order_book.all_orders:
            print(f'{order.company} {order.order_type} {order.action} '
                  f'${order.price}, {order.filled_quantity}/{order.quantity} {order.status}')






class OrderBook:
    def __init__(self):
        self.buy_orders = []
        self.sell_orders = []
        self.all_orders = []

    def create_limit_order(self, action, company, price, quantity):
        return Order(action, company, 'LMT', price, quantity)

    def create_market_order(self, action, company, quantity):
        return Order(action, company, 'MKT', None, quantity)

    def add_order(self, order):
        self.all_orders.append(order)
        if order.order_type == 'LMT':
            if order.action == 'BUY':
                self.buy_orders.append(order)
            if order.action == 'SELL':
                self.sell_orders.append(order)
        self.match_orders()

    def match_orders(self):
        self.buy_orders.sort(key=lambda x: (-x.price, x.timestamp))
        self.sell_orders.sort(key=lambda x: (x.price, x.timestamp))
        for buy_order in self.buy_orders:
            for sell_order in self.sell_orders:
                if (buy_order.price >= sell_order.price and
                    buy_order.status == 'PENDING' and
                    sell_order.status == 'PENDING' and
                    buy_order.company == sell_order.company):
                    buy_remaining = buy_order.quantity - buy_order.filled_quantity
                    sell_remaining = sell_order.quantity - sell_order.filled_quantity
                    fill_amount = min(buy_remaining, sell_remaining)
                    buy_order.fill(fill_amount)
                    sell_order.fill(fill_amount)


class PriceFeed:
    def __init__(self, order_book):
        self.order_book = order_book
        self.bid = 0
        self.ask = 0

    def update_prices(self):
        buy_orders = self.order_book.buy_orders
        sell_orders = self.order_book.sell_orders
        if buy_orders:
            self.bid = max(order.price for order in buy_orders)
        else:
            self.bid = 0

        if sell_orders:
            self.ask = min(order.price for order in sell_orders)
        else:
            self.ask = 0

    def get_last_price(self, company):
        filled_orders = [order for order in self.order_book.all_orders
                         if (order.company == company and order.filled_quantity > 0)
                         ]
        return filled_orders[-1].price if filled_orders else None

        # if current_company_list:
        #     print(f'{company} BID: {self.bid} ASK: {self.ask}, LAST: {current_company_list[-1].price}')
        # else:
        #     print(f'Ордера на покупку/продажу акций компании {company} не выставлялись')

    def get_market_data(self, company):
        last_price = self.get_last_price(company)
        return {
            'company': company,
            'bid': self.bid,
            'ask': self.ask,
            'last': last_price
        }





